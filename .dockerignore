# .dockerignore
# Files and folders excluded from the Docker build context.
# Keeping the build context small makes builds faster and
# prevents sensitive files from entering the container.

# Dependencies — reinstalled fresh inside the container
node_modules

# Next.js build output — rebuilt inside the container
.next

# Environment files — injected at runtime, never baked in
.env
.env.local
.env.development
.env.production

# Git history — not needed inside the container
.git
.gitignore

# Test files — not needed in production
__tests__
jest.config.js

# Editor and OS files
.vscode
.DS_Store
Thumbs.db

# Docker files — not needed inside the container
Dockerfile
docker-compose.yml
nginx.conf

# Documentation
README.md